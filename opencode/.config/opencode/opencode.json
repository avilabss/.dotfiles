{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "small_model": "openai/gpt-5.6-luna",
  "default_agent": "architect",
  "enabled_providers": ["openai"],
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000
      }
    }
  },
  "autoupdate": true,
  "share": "disabled",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "target/**",
      ".venv/**",
      "__pycache__/**",
      ".next/**",
      "coverage/**"
    ]
  },
  "server": {
    "port": 4096
  },
  "shell": "/usr/bin/zsh"
}
